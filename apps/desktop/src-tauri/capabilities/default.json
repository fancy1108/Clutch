{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Clutch desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-clutch-sidecar-token",
    "allow-clutch-app-commands",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "orchestrator",
          "sidecar": true
        }
      ]
    },
    "updater:default",
    "process:default"
  ]
}
