{
  "name": "clutch",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter @clutch/desktop dev",
    "build": "pnpm --filter @clutch/desktop build",
    "preview": "pnpm --filter @clutch/desktop preview",
    "lint": "pnpm -r lint",
    "clean": "pnpm --filter @clutch/desktop clean",
    "test": "pnpm --filter @clutch/desktop test",
    "tauri:dev": "bash scripts/tauri-dev.sh",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
